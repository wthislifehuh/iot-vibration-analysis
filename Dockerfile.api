FROM python:3.10-slim
WORKDIR /app

# Ensure Phase 4 PostgreSQL and API dependencies are layered over Phase 3 math bounds
RUN pip install --no-cache-dir fastapi uvicorn sqlalchemy psycopg2-binary clickhouse-connect pydantic python-dotenv numpy scipy scikit-learn

COPY . .

# Launch ASGI framework exposing on 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
